---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchZennFeed } from '../../lib/zenn';

const posts = await fetchZennFeed();
---

<BaseLayout title="Blog" description="Zenn の技術記事一覧">
  <h1>Blog</h1>
  <p class="lead">
    <a href="https://zenn.dev/misumith" target="_blank" rel="noopener">Zenn</a> に投稿した記事の一覧です。
  </p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={post.url} target="_blank" rel="noopener">
          <span class="post-title">{post.title}</span>
          <time datetime={post.pubDate.toISOString()}>
            {post.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .lead {
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }

  .post-list {
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    color: var(--color-text);
    gap: 1rem;
  }

  .post-list a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-title {
    font-weight: 500;
  }

  time {
    color: var(--color-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    white-space: nowrap;
  }
</style>
