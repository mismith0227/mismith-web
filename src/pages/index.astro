---
import BaseLayout from '../layouts/BaseLayout.astro';
import { works } from '../data/works';
import { fetchZennFeed } from '../lib/zenn';

const recentPosts = (await fetchZennFeed()).slice(0, 3);

function periodLabel(period: { start: string; end: string }) {
  return period.end === '継続中'
    ? `${period.start} 〜 継続中`
    : `${period.start} 〜 ${period.end}`;
}
---

<BaseLayout title="Home">
  <!-- Hero / Profile -->
  <section class="hero">
    <p class="eyebrow">Web Engineer</p>
    <h1>Takuma<br />Misumi</h1>
    <p class="bio">
      大阪在住のwebエンジニア
    </p>
    <div class="links">
      <a href="https://github.com/mismith0227" target="_blank" rel="noopener">GitHub</a>
      <a href="https://x.com/misumi_takuma" target="_blank" rel="noopener">X (Twitter)</a>
    </div>
  </section>

  <!-- Works -->
  <section class="section">
    <h2>Works</h2>
    <ul class="works-list">
      {works.map((work) => (
        <li class="work-item">
          <div class="work-header">
            <span class="company">{work.company}</span>
            <span class="period">{periodLabel(work.period)}</span>
          </div>
          <ul class="project-list">
            {work.projects.map((project) => (
              <li class="project-item">
                <div class="project-header">
                  <span class="project-name">{project.name}</span>
                  <span class="period">{periodLabel(project.period)}</span>
                </div>
                <p class="project-role">{project.role}</p>
                <p class="project-desc">{project.description}</p>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </section>

  <!-- Recent Blog Posts -->
  <section class="section">
    <div class="section-header">
      <h2>Blog</h2>
      <a href="/blog">すべて見る →</a>
    </div>
    <ul class="post-list">
      {recentPosts.map((post) => (
        <li>
          <a href={post.url} target="_blank" rel="noopener">
            <span class="post-title">{post.title}</span>
            <time datetime={post.pubDate.toISOString()}>
              {post.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .bio {
    color: var(--color-muted);
    font-size: 1.05rem;
    margin-top: 1.5rem;
    max-width: 520px;
  }

  .links {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .section {
    margin-bottom: 4rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
  }

  /* Works list */
  .works-list {
    list-style: none;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .work-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .company {
    font-weight: 700;
    color: var(--color-text);
  }

  .period {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--color-muted);
  }

  /* Project list — indented to show nesting */
  .project-list {
    list-style: none;
    border-left: 1px solid var(--color-border);
    margin-left: 0.25rem;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .project-item:last-child {
    border-bottom: none;
  }

  .project-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .project-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .project-role {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-bottom: 0.3rem;
  }

  .project-desc {
    font-size: 0.88rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Post list */
  .post-list {
    list-style: none;
  }

  .post-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    color: var(--color-text);
    gap: 1rem;
  }

  .post-list a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-title {
    font-weight: 500;
  }

  time {
    color: var(--color-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    white-space: nowrap;
  }
</style>
