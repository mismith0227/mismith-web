---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Takuma Misumi のポートフォリオサイト" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | mismith.dev</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">mismith.dev</a>
        <ul>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>&copy; 2026 Takuma Misumi</p>
    </footer>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #0f0f0f;
    --color-surface: #1a1a1a;
    --color-border: #2a2a2a;
    --color-text: #e8e8e8;
    --color-muted: #888;
    --color-accent: #7c6af7;
    --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --font-mono: "SF Mono", "Fira Code", monospace;
    --max-width: 800px;
  }

  html {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
  }

  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  /* Header */
  header {
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg);
    z-index: 10;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  nav ul a {
    color: var(--color-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  nav ul a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  /* Main */
  main {
    flex: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--color-border);
    text-align: center;
    padding: 2rem 1.5rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  /* Typography */
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.2;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  code {
    font-family: var(--font-mono);
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
  }

  pre {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  pre code {
    background: none;
    padding: 0;
    font-size: 0.85rem;
  }

  /* Tag pill */
  .tag {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.2em 0.65em;
    border-radius: 999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  /* Card */
  .card {
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    background: var(--color-surface);
    transition: border-color 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
  }
</style>
